    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.18",
    "storybook": "^10.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
