{
  "name": "project-genesis-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "sync:studio-runtime": "tsx scripts/sync-studio-runtime.ts",
    "verify:dashboard-assets": "node scripts/verify-dashboard-assets.mjs",
    "verify:architecture-reference": "node scripts/verify-architecture-reference.mjs",
    "verify:design-system": "node scripts/verify-design-system.mjs",
    "verify:cinematic-rendering": "node scripts/verify-cinematic-rendering.mjs",
    "verify:mobile-readiness": "node scripts/verify-mobile-readiness.mjs",
    "verify:app-shell-consumption": "node scripts/verify-app-shell-consumption.mjs",
    "verify:discovery-runtime": "node scripts/verify-discovery-runtime.mjs",
    "verify:discovery-determinism": "vitest run src/test/discovery.test.ts",
    "verify:discovery-save": "vitest run src/test/discovery-save.test.ts",
    "verify:discovery-registry": "node scripts/verify-discovery-registry.mjs",
    "verify:exploration-gameplay": "vitest run src/test/exploration-gameplay.test.ts src/test/galaxy-map.test.tsx",
    "verify:planet-evaluation": "node scripts/verify-planet-evaluation.mjs",
    "verify:semantic-zoom": "vitest run src/test/galaxy-map.test.tsx",
    "verify:supabase-game": "node scripts/verify-supabase-game.mjs",
    "storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --disable-telemetry",
